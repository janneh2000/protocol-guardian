# ─── Alchemy RPC ──────────────────────────────────────────────
# Get from: https://dashboard.alchemy.com → Create App → Sepolia
ALCHEMY_WS_RPC=wss://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_HTTP_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ─── Anthropic ────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Wallet Keys ──────────────────────────────────────────────
# DEPLOYER: Account that deploys the contracts. Needs Sepolia ETH.
# Get Sepolia ETH: https://sepoliafaucet.com/
DEPLOYER_PRIVATE_KEY=0x...

# GUARDIAN HOT WALLET: The AI agent's signing key.
# Can be the same as DEPLOYER for hackathon simplicity.
# In production: separate key, minimal ETH balance, key rotatable.
GUARDIAN_HOT_WALLET_PRIVATE_KEY=0x...

# GUARDIAN_HOT_WALLET is the ADDRESS derived from the key above.
# Run: python scripts/get_address.py to find it.
GUARDIAN_HOT_WALLET=0x...

# ATTACKER: For running attack_simulator.py (demo only).
# Can reuse DEPLOYER_PRIVATE_KEY for the hackathon.
ATTACKER_PRIVATE_KEY=0x...

# ─── Contract Addresses (filled after deployment) ─────────────
# Run: npx hardhat run scripts/deploy.js --network sepolia
# Then copy the output here.
LENDING_POOL_ADDRESS=0x...
GUARDIAN_CONTRACT_ADDRESS=0x...

# ─── Optional — Alerts ────────────────────────────────────────
# Discord: Create a webhook in your server settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram: Create a bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Optional — Etherscan verification ───────────────────────
ETHERSCAN_API_KEY=

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
